<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__Tab</target>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__RecordPage,lightning__HomePage">
            <property name="variant"    type="String"  default="default" label="Tab Variant"
                      description="Styling variant: default | scoped | vertical" />
            <property name="defaultTab" type="String"  default=""        label="Default Tab Value"
                      description="Value of the tab to activate on load" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
